<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beeo_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEEO"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/beeo_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tu resumen de hoy"
                    android:textSize="14sp"
                    android:textColor="@color/beeo_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Trend Banner -->
        <TextView
            android:id="@+id/tvTrendBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargando datos..."
            android:textColor="@color/white"
            android:textSize="13sp"
            android:padding="12dp"
            android:gravity="center" />

        <!-- Today Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/beeo_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actividad de hoy"
                    android:textSize="14sp"
                    android:textColor="@color/beeo_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTodaySteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="@color/beeo_primary" />

                <TextView
                    android:id="@+id/tvStepsGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pasos"
                    android:textSize="13sp"
                    android:textColor="@color/beeo_text_secondary"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progressSteps"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:progressTint="@color/beeo_primary"
                    android:progressBackgroundTint="@color/beeo_surface_variant"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTodayDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/beeo_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distancia"
                            android:textSize="11sp"
                            android:textColor="@color/beeo_text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTodayActive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/beeo_success" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activo"
                            android:textSize="11sp"
                            android:textColor="@color/beeo_text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTodayZones"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/beeo_warning" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zonas"
                            android:textSize="11sp"
                            android:textColor="@color/beeo_text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Steps Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/beeo_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pasos por día (últimas 2 semanas)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/beeo_text_primary"
                    android:layout_marginBottom="12dp" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/stepsChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- History Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historial de actividad"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/beeo_text_primary"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp" />

        <!-- Activity History List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvActivityHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
