<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beeo_background">

    <!-- Círculo decorativo superior -->
    <View
        android:id="@+id/circle_top"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_circle_gradient"
        android:alpha="0.08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-80dp"
        android:layout_marginTop="-80dp"/>

    <!-- Círculo decorativo inferior -->
    <View
        android:id="@+id/circle_bottom"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_circle_gradient"
        android:alpha="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-60dp"/>

    <!-- Ícono / Logo -->
    <TextView
        android:id="@+id/tv_logo_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="🐝"
        android:textSize="44sp"
        android:gravity="center"
        android:background="@drawable/bg_logo_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_app_name"
        android:layout_marginBottom="20dp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35"/>

    <!-- Nombre de la app -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BEEO"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="@color/beeo_text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_logo_icon"
        app:layout_constraintBottom_toTopOf="@id/tv_tagline"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu compañero de bienestar"
        android:textSize="16sp"
        android:textColor="@color/beeo_text_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_app_name"
        app:layout_constraintBottom_toTopOf="@id/card_login"/>

    <!-- Card de login -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="@color/beeo_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_tagline"
        app:layout_constraintBottom_toTopOf="@id/tv_terms"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar sesión"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/beeo_text_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usa tu cuenta de Google para continuar"
                android:textSize="14sp"
                android:textColor="@color/beeo_text_secondary"
                android:layout_marginBottom="28dp"/>

            <!-- Botón Google personalizado -->
            <FrameLayout
                android:id="@+id/btn_google_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_google_button"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Letra G como logo (evita dependencia de imagen) -->
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="G"
                        android:textColor="#4285F4"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_google_icon"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continuar con Google"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/beeo_text_primary"/>

                </LinearLayout>

            </FrameLayout>

            <!-- ProgressBar dentro del card -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="@color/beeo_primary"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Texto de términos -->
    <TextView
        android:id="@+id/tv_terms"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:text="Al continuar, aceptas nuestros Términos de servicio y Política de privacidad"
        android:textSize="12sp"
        android:textColor="@color/beeo_text_secondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
