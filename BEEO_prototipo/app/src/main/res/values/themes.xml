<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BEEO" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/beeo_primary</item>
        <item name="colorOnPrimary">@color/beeo_background</item>
        <item name="colorSecondary">@color/beeo_secondary</item>
        <item name="colorSurface">@color/beeo_surface</item>
        <item name="colorOnSurface">@color/beeo_text_primary</item>
        <item name="android:colorBackground">@color/beeo_background</item>
        <item name="android:windowBackground">@color/beeo_background</item>
        <item name="android:statusBarColor">@color/beeo_background</item>
        <item name="android:navigationBarColor">@color/beeo_surface</item>
    </style>

    <style name="Theme.BEEO.Splash" parent="Theme.BEEO">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Widget.BEEO.DayButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">12sp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="strokeColor">@color/beeo_surface_variant</item>
        <item name="android:textColor">@color/beeo_text_primary</item>
        <item name="backgroundTint">@color/beeo_surface</item>
    </style>

    <style name="Widget.BEEO.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/beeo_surface_variant</item>
    </style>

</resources>
